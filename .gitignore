# Dependencies
node_modules/
.pnpm-store/

# Claude harness
.claude/scheduled_tasks.lock

# Builds
dist/
build/
.output/
.turbo/

# TypeScript incremental
*.tsbuildinfo
.tsbuildinfo-*/

# Tauri
**/src-tauri/target/
**/src-tauri/gen/schemas/
**/src-tauri/Cargo.lock

# iOS / Xcode — gen/apple is regenerated by `tauri ios init`, but we keep the
# parts we customize: project.yml (adds the Resources folder reference for the
# CoreML speaker model — see apps/mobile/src-tauri/build.rs and VoicePlugin.swift)
# and Resources/ (the runtime drop-zone for SpeakerECAPA.mlmodelc).
**/src-tauri/gen/apple/*
!**/src-tauri/gen/apple/project.yml
!**/src-tauri/gen/apple/Resources
**/src-tauri/gen/apple/Resources/*
!**/src-tauri/gen/apple/Resources/.gitkeep
*.xcuserstate
xcuserdata/
DerivedData/

# Env
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Editor
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
.DS_Store

# DB
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
*.db
data/
# Allow CoreML .mlpackage internals (the binary `Data/` subdir matches the
# generic `data/` rule above on case-insensitive filesystems).
!apps/mobile/src-tauri/ios/Models/**/Data/
!apps/mobile/src-tauri/ios/Models/**/Data/**
.playwright-mcp/