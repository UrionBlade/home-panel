# Fastlane runs on macOS (locally or in CI) and does four things in order:
# 1. Provision a throwaway keychain with our Distribution certificate and
#    install the App Store provisioning profile.
# 2. Stamp the Info.plist CFBundleVersion so each upload is monotonically
#    increasing (TestFlight rejects duplicate build numbers).
# 3. Run the Tauri iOS build, which produces an .ipa ready for the store.
# 4. Upload to TestFlight via the App Store Connect API key.
#
# Required env variables (provided by the workflow):
#   IOS_P12_BASE64                - distribution cert .p12, base64-encoded
#   IOS_P12_PASSWORD              - password chosen at .p12 export time
#   IOS_PROVISIONING_PROFILE_BASE64 - App Store provisioning profile, base64
#   ASC_API_KEY_BASE64            - App Store Connect API key .p8, base64
#   ASC_API_KEY_ID                - API key id (10 chars)
#   ASC_API_KEY_ISSUER_ID         - API key issuer uuid
#   IOS_TEAM_ID                   - Apple developer team id
#
# Build number strategy: use GITHUB_RUN_NUMBER (strictly increasing per repo).
# Fallback to current unix timestamp for local runs.

default_platform(:ios)

IOS_PROJECT_ROOT = File.expand_path("..", __dir__)
REPO_ROOT = File.expand_path("../..", IOS_PROJECT_ROOT)
TAURI_IOS_ROOT = File.join(IOS_PROJECT_ROOT, "src-tauri", "gen", "apple")
INFO_PLIST = File.join(TAURI_IOS_ROOT, "mobile_iOS", "Info.plist")
EXPORT_OPTIONS_PLIST = File.join(TAURI_IOS_ROOT, "ExportOptions.plist")

platform :ios do
  desc "Build and upload a new TestFlight build"
  lane :release do
    setup_signing
    ensure_ios_project
    generate_icons
    stamp_build_number
    configure_push_capability
    build_tauri_ios
    upload_build
  end

  desc "Just set up signing — useful for debugging in CI"
  lane :signing do
    setup_signing
  end

  # `tauri ios init` scaffolds gen/apple/ from tauri.conf.json. The folder is
  # gitignored, so a fresh CI checkout never has it. Running init is idempotent
  # and fast once the Rust target is installed.
  private_lane :ensure_ios_project do
    Dir.chdir(IOS_PROJECT_ROOT) do
      sh("pnpm tauri ios init")
    end

    patch_project_yml_for_speaker_model

    # Tauri generates the Xcode project with automatic signing. On CI we use
    # manual signing with the distribution cert + provisioning profile that
    # Fastlane installed in setup_signing. The profile's display name can
    # differ from what we typed on the developer portal, so extract it from
    # the .mobileprovision file itself rather than hardcoding.
    profile_path = "/tmp/HomePanel_AppStore.mobileprovision"
    profile_plist = "/tmp/HomePanel_AppStore.plist"
    sh("/usr/bin/security cms -D -i '#{profile_path}' > '#{profile_plist}'")
    profile_name = sh(
      "/usr/libexec/PlistBuddy -c 'Print :Name' '#{profile_plist}'",
      log: false,
    ).strip
    profile_uuid = sh(
      "/usr/libexec/PlistBuddy -c 'Print :UUID' '#{profile_plist}'",
      log: false,
    ).strip
    UI.message("Using provisioning profile '#{profile_name}' (UUID #{profile_uuid})")

    # update_code_signing_settings only rewrites build_settings. Xcode also
    # reads TargetAttributes.ProvisioningStyle from the project root, and if
    # that still says "Automatic" the build settings are ignored. We patch
    # both via the Xcodeproj gem.
    require "xcodeproj"
    project = Xcodeproj::Project.open(File.join(TAURI_IOS_ROOT, "mobile.xcodeproj"))
    target = project.targets.find { |t| t.name == "mobile_iOS" }
    UI.user_error!("mobile_iOS target not found") unless target

    attrs = project.root_object.attributes
    attrs["TargetAttributes"] ||= {}
    attrs["TargetAttributes"][target.uuid] ||= {}
    attrs["TargetAttributes"][target.uuid]["ProvisioningStyle"] = "Manual"
    attrs["TargetAttributes"][target.uuid]["DevelopmentTeam"] = ENV.fetch("IOS_TEAM_ID")

    target.build_configurations.each do |config|
      config.build_settings["CODE_SIGN_STYLE"] = "Manual"
      config.build_settings["DEVELOPMENT_TEAM"] = ENV.fetch("IOS_TEAM_ID")
      config.build_settings["CODE_SIGN_IDENTITY"] = "Apple Distribution"
      config.build_settings["PROVISIONING_PROFILE_SPECIFIER"] = profile_name
      config.build_settings["PROVISIONING_PROFILE"] = profile_uuid
    end

    project.save
    UI.message("Patched pbxproj: manual signing applied to all configs + TargetAttributes")

    # Tauri uses its own ExportOptions.plist for the xcodebuild -exportArchive
    # step. The default it generates asks for automatic signing, which fails
    # on a CI runner with no Apple ID logged in. Write an explicit manual
    # export-options file and make tauri use it via --export-options.
    File.write(EXPORT_OPTIONS_PLIST, <<~PLIST)
      <?xml version="1.0" encoding="UTF-8"?>
      <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
      <plist version="1.0">
      <dict>
        <key>method</key>
        <string>app-store-connect</string>
        <key>signingStyle</key>
        <string>manual</string>
        <key>teamID</key>
        <string>#{ENV.fetch("IOS_TEAM_ID")}</string>
        <key>signingCertificate</key>
        <string>Apple Distribution</string>
        <key>provisioningProfiles</key>
        <dict>
          <key>com.matteopoli.homepanel</key>
          <string>#{profile_name}</string>
        </dict>
        <key>stripSwiftSymbols</key>
        <true/>
      </dict>
      </plist>
    PLIST
    UI.message("Wrote ExportOptions.plist with manual signing")
  end

  # `tauri ios init` regenerates project.yml from Tauri's iOS template, which
  # doesn't know about our CoreML speaker model. The model is compiled by
  # build.rs into gen/apple/Resources/SpeakerECAPA.mlmodelc and we need that
  # folder referenced in the Xcode resources buildPhase, otherwise
  # `Bundle.main.url(forResource: "SpeakerECAPA", ...)` returns nil at runtime
  # and voice enrolment hits the 4s timeout. Idempotent: a second run is a
  # no-op once the entry is already present.
  private_lane :patch_project_yml_for_speaker_model do
    require "yaml"
    project_yml = File.join(TAURI_IOS_ROOT, "project.yml")
    UI.user_error!("project.yml not found at #{project_yml}") unless File.exist?(project_yml)

    config = YAML.load_file(project_yml)
    sources = config.dig("targets", "mobile_iOS", "sources")
    UI.user_error!("mobile_iOS.sources missing in project.yml") unless sources.is_a?(Array)

    already_patched = sources.any? do |entry|
      entry.is_a?(Hash) && entry["path"] == "Resources"
    end

    if already_patched
      UI.message("project.yml already references Resources/ — skipping patch")
    else
      sources << {
        "path" => "Resources",
        "buildPhase" => "resources",
        "type" => "folder",
        "optional" => true,
      }
      File.write(project_yml, config.to_yaml)
      UI.message("Patched project.yml: added Resources folder reference")

      # Re-run xcodegen so the new path lands in mobile.xcodeproj. Tauri does
      # the initial xcodegen as part of `tauri ios init`; we just need it
      # again with the patched yaml.
      Dir.chdir(TAURI_IOS_ROOT) do
        sh("xcodegen generate")
      end
    end

    # build.rs writes the compiled model here during `tauri ios build`, but
    # xcodegen complained on at least one CI run when the folder didn't exist
    # at project-generation time. Pre-create it so the resources buildPhase
    # always has something to point at.
    FileUtils.mkdir_p(File.join(TAURI_IOS_ROOT, "Resources"))
  end

  private_lane :setup_signing do
    # A dedicated, ephemeral keychain avoids leaving secrets in the default one.
    keychain_name = "home-panel-ci.keychain-db"
    keychain_password = SecureRandom.hex(16)

    # Delete any leftover keychain from a previous failed run.
    sh("security delete-keychain #{keychain_name} 2>/dev/null || true")

    create_keychain(
      name: keychain_name,
      password: keychain_password,
      default_keychain: false,
      unlock: true,
      timeout: 1800,
      lock_when_sleeps: false,
    )

    p12_path = "/tmp/ios_distribution.p12"
    File.binwrite(p12_path, Base64.decode64(ENV.fetch("IOS_P12_BASE64")))

    import_certificate(
      certificate_path: p12_path,
      certificate_password: ENV.fetch("IOS_P12_PASSWORD"),
      keychain_name: keychain_name,
      keychain_password: keychain_password,
    )

    profile_path = "/tmp/HomePanel_AppStore.mobileprovision"
    File.binwrite(profile_path, Base64.decode64(ENV.fetch("IOS_PROVISIONING_PROFILE_BASE64")))

    install_provisioning_profile(path: profile_path)

    File.delete(p12_path) if File.exist?(p12_path)
  end

  # Overwrite the default Tauri icons in gen/apple's AppIcon.appiconset with
  # variants rendered from src-tauri/icons/icon.png. Without this, a fresh
  # `tauri ios init` on CI leaves the built-in Tauri "T" placeholder.
  private_lane :generate_icons do
    Dir.chdir(IOS_PROJECT_ROOT) do
      sh("pnpm tauri icon src-tauri/icons/icon.png")
    end
  end

  private_lane :stamp_build_number do
    # Only inject privacy strings here. CFBundleVersion is handled by
    # `tauri ios build --build-number` since Tauri rewrites Info.plist
    # from tauri.conf.json during the build and would clobber any
    # PlistBuddy patch we made at this stage.
    mic_reason = "Home Panel uses the microphone to recognise your voice commands."
    speech_reason = "Home Panel processes your voice locally to execute household commands."

    sh(<<~SHELL)
      set -e
      plist="#{INFO_PLIST}"
      set_or_add() {
        /usr/libexec/PlistBuddy -c "Set :$1 $3" "$plist" 2>/dev/null \
          || /usr/libexec/PlistBuddy -c "Add :$1 $2 $3" "$plist"
      }
      set_or_add NSMicrophoneUsageDescription string "#{mic_reason}"
      set_or_add NSSpeechRecognitionUsageDescription string "#{speech_reason}"
    SHELL
  end

  # Tauri's `gen/apple/` is regenerated from scratch on every CI run by
  # `tauri ios init`, so any manual change to Info.plist or
  # mobile_iOS.entitlements would get clobbered. Patch them here, after
  # `ensure_ios_project`, with the bits APNs push notifications need:
  #   - `aps-environment = production` in entitlements
  #   - `UIBackgroundModes` includes `remote-notification` in Info.plist
  # Both are idempotent: re-running with values already set is a no-op.
  private_lane :configure_push_capability do
    entitlements = File.join(TAURI_IOS_ROOT, "mobile_iOS", "mobile_iOS.entitlements")
    sh(<<~SHELL)
      set -e
      ent="#{entitlements}"
      /usr/libexec/PlistBuddy -c "Set :aps-environment production" "$ent" 2>/dev/null \
        || /usr/libexec/PlistBuddy -c "Add :aps-environment string production" "$ent"
    SHELL

    sh(<<~SHELL)
      set -e
      plist="#{INFO_PLIST}"
      # Make sure UIBackgroundModes is an array containing remote-notification.
      /usr/libexec/PlistBuddy -c "Print :UIBackgroundModes" "$plist" >/dev/null 2>&1 \
        || /usr/libexec/PlistBuddy -c "Add :UIBackgroundModes array" "$plist"
      # Idempotent: only append remote-notification when missing.
      /usr/libexec/PlistBuddy -c "Print :UIBackgroundModes" "$plist" \
        | grep -q "remote-notification" \
        || /usr/libexec/PlistBuddy -c "Add :UIBackgroundModes:0 string remote-notification" "$plist"
    SHELL
  end

  private_lane :build_tauri_ios do
    # Our manual-signing ExportOptions.plist was written at
    # gen/apple/ExportOptions.plist in ensure_ios_project; Tauri picks up
    # that file for the -exportArchive step.
    # CFBundleVersion is taken verbatim from tauri.conf.json `version`, so
    # bump that file to ship a new build (e.g. "0.1.1" -> "0.1.2").
    Dir.chdir(IOS_PROJECT_ROOT) do
      sh("pnpm tauri ios build --export-method app-store-connect")
    end
  end

  private_lane :upload_build do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_API_KEY_ID"),
      issuer_id: ENV.fetch("ASC_API_KEY_ISSUER_ID"),
      key_content: Base64.decode64(ENV.fetch("ASC_API_KEY_BASE64")),
      is_key_content_base64: false,
      duration: 1200,
      in_house: false,
    )

    ipa_glob = File.join(TAURI_IOS_ROOT, "build", "**", "*.ipa")
    ipa_path = Dir.glob(ipa_glob).max_by { |f| File.mtime(f) }
    UI.user_error!("No .ipa produced under #{ipa_glob}") if ipa_path.nil?
    UI.message("Uploading #{ipa_path}")

    # Drop changelog: setting it forces Fastlane to wait for the build to
    # appear in App Store Connect so it can be attached, which adds 20+
    # minutes of polling and occasionally times the job out. The commit SHA
    # is already in the job's Git log.
    upload_to_testflight(
      api_key: api_key,
      ipa: ipa_path,
      skip_waiting_for_build_processing: true,
      skip_submission: true,
    )
  end
end
