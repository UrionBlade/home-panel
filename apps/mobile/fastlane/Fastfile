# Fastlane runs on macOS (locally or in CI) and does four things in order:
# 1. Provision a throwaway keychain with our Distribution certificate and
#    install the App Store provisioning profile.
# 2. Stamp the Info.plist CFBundleVersion so each upload is monotonically
#    increasing (TestFlight rejects duplicate build numbers).
# 3. Run the Tauri iOS build, which produces an .ipa ready for the store.
# 4. Upload to TestFlight via the App Store Connect API key.
#
# Required env variables (provided by the workflow):
#   IOS_P12_BASE64                - distribution cert .p12, base64-encoded
#   IOS_P12_PASSWORD              - password chosen at .p12 export time
#   IOS_PROVISIONING_PROFILE_BASE64 - App Store provisioning profile, base64
#   ASC_API_KEY_BASE64            - App Store Connect API key .p8, base64
#   ASC_API_KEY_ID                - API key id (10 chars)
#   ASC_API_KEY_ISSUER_ID         - API key issuer uuid
#   IOS_TEAM_ID                   - Apple developer team id
#
# Build number strategy: use GITHUB_RUN_NUMBER (strictly increasing per repo).
# Fallback to current unix timestamp for local runs.

require "json"

default_platform(:ios)

IOS_PROJECT_ROOT = File.expand_path("..", __dir__)
REPO_ROOT = File.expand_path("../..", IOS_PROJECT_ROOT)
TAURI_IOS_ROOT = File.join(IOS_PROJECT_ROOT, "src-tauri", "gen", "apple")
INFO_PLIST = File.join(TAURI_IOS_ROOT, "mobile_iOS", "Info.plist")
EXPORT_OPTIONS_PLIST = File.join(TAURI_IOS_ROOT, "ExportOptions.plist")

platform :ios do
  desc "Build and upload a new TestFlight build"
  lane :release do
    setup_signing
    ensure_ios_project
    generate_icons
    stamp_build_number
    configure_push_capability
    build_tauri_ios
    upload_build
  end

  desc "Just set up signing — useful for debugging in CI"
  lane :signing do
    setup_signing
  end

  # `tauri ios init` scaffolds gen/apple/ from tauri.conf.json. The folder is
  # gitignored, so a fresh CI checkout never has it. Running init is idempotent
  # and fast once the Rust target is installed.
  private_lane :ensure_ios_project do
    Dir.chdir(IOS_PROJECT_ROOT) do
      sh("pnpm tauri ios init")
    end

    patch_project_yml_for_speaker_model

    # Tauri generates the Xcode project with automatic signing. On CI we use
    # manual signing with the distribution cert + provisioning profile that
    # Fastlane installed in setup_signing. The profile's display name can
    # differ from what we typed on the developer portal, so extract it from
    # the .mobileprovision file itself rather than hardcoding.
    profile_path = "/tmp/HomePanel_AppStore.mobileprovision"
    profile_plist = "/tmp/HomePanel_AppStore.plist"
    sh("/usr/bin/security cms -D -i '#{profile_path}' > '#{profile_plist}'")
    profile_name = sh(
      "/usr/libexec/PlistBuddy -c 'Print :Name' '#{profile_plist}'",
      log: false,
    ).strip
    profile_uuid = sh(
      "/usr/libexec/PlistBuddy -c 'Print :UUID' '#{profile_plist}'",
      log: false,
    ).strip
    UI.message("Using provisioning profile '#{profile_name}' (UUID #{profile_uuid})")

    # update_code_signing_settings only rewrites build_settings. Xcode also
    # reads TargetAttributes.ProvisioningStyle from the project root, and if
    # that still says "Automatic" the build settings are ignored. We patch
    # both via the Xcodeproj gem.
    require "xcodeproj"
    project = Xcodeproj::Project.open(File.join(TAURI_IOS_ROOT, "mobile.xcodeproj"))
    target = project.targets.find { |t| t.name == "mobile_iOS" }
    UI.user_error!("mobile_iOS target not found") unless target

    attrs = project.root_object.attributes
    attrs["TargetAttributes"] ||= {}
    attrs["TargetAttributes"][target.uuid] ||= {}
    attrs["TargetAttributes"][target.uuid]["ProvisioningStyle"] = "Manual"
    attrs["TargetAttributes"][target.uuid]["DevelopmentTeam"] = ENV.fetch("IOS_TEAM_ID")

    target.build_configurations.each do |config|
      config.build_settings["CODE_SIGN_STYLE"] = "Manual"
      config.build_settings["DEVELOPMENT_TEAM"] = ENV.fetch("IOS_TEAM_ID")
      config.build_settings["CODE_SIGN_IDENTITY"] = "Apple Distribution"
      config.build_settings["PROVISIONING_PROFILE_SPECIFIER"] = profile_name
      config.build_settings["PROVISIONING_PROFILE"] = profile_uuid
      # Reassert PRODUCT_BUNDLE_IDENTIFIER at the configuration level —
      # Xcode 26's xcodebuild archive reads it from the active config's
      # build settings (not from the .app's Info.plist) when populating
      # the .xcarchive's ApplicationProperties.CFBundleIdentifier. If
      # it's blank or inherited-only, exportArchive bails with
      # "Archive Missing Bundle Identifier".
      config.build_settings["PRODUCT_BUNDLE_IDENTIFIER"] = "com.matteopoli.homepanel"
    end

    project.save
    UI.message("Patched pbxproj: manual signing applied to all configs + TargetAttributes")

    # Tauri uses its own ExportOptions.plist for the xcodebuild -exportArchive
    # step. The default it generates asks for automatic signing, which fails
    # on a CI runner with no Apple ID logged in. Write an explicit manual
    # export-options file and make tauri use it via --export-options.
    File.write(EXPORT_OPTIONS_PLIST, <<~PLIST)
      <?xml version="1.0" encoding="UTF-8"?>
      <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
      <plist version="1.0">
      <dict>
        <key>destination</key>
        <string>export</string>
        <key>method</key>
        <string>app-store-connect</string>
        <key>signingStyle</key>
        <string>manual</string>
        <key>teamID</key>
        <string>#{ENV.fetch("IOS_TEAM_ID")}</string>
        <key>signingCertificate</key>
        <string>Apple Distribution</string>
        <key>provisioningProfiles</key>
        <dict>
          <key>com.matteopoli.homepanel</key>
          <string>#{profile_name}</string>
        </dict>
        <key>stripSwiftSymbols</key>
        <true/>
        <key>compileBitcode</key>
        <false/>
        <key>uploadSymbols</key>
        <false/>
      </dict>
      </plist>
    PLIST
    UI.message("Wrote ExportOptions.plist with manual signing")
  end

  # The CoreML SpeakerECAPA model lives in gen/apple/Resources/ at build
  # time (build.rs compiles ios/Models/SpeakerECAPA.mlpackage into it), but
  # `tauri ios init` regenerates project.yml without that path. We patch
  # the resulting mobile.xcodeproj DIRECTLY via the Xcodeproj gem instead
  # of re-running xcodegen — a second `xcodegen generate` was producing a
  # subtly different pbxproj that broke codesign on Xcode 16.4 (libapp.a
  # ended up double-listed in the Resources phase, codesign chokes on
  # the AppIcon files inside the partially-signed bundle).
  #
  # Idempotent: re-running with the entry already present is a no-op.
  private_lane :patch_project_yml_for_speaker_model do
    require "xcodeproj"

    # Always pre-create the folder so the file reference resolves on disk
    # even before build.rs has populated it (xcodebuild still validates
    # that referenced paths exist).
    resources_dir = File.join(TAURI_IOS_ROOT, "Resources")
    FileUtils.mkdir_p(resources_dir)
    FileUtils.touch(File.join(resources_dir, ".gitkeep"))

    project_path = File.join(TAURI_IOS_ROOT, "mobile.xcodeproj")
    project = Xcodeproj::Project.open(project_path)
    target = project.targets.find { |t| t.name == "mobile_iOS" }
    UI.user_error!("mobile_iOS target not found") unless target

    # Skip when a Resources folder reference already exists at the project
    # root group — guards against double-injection on retries.
    existing = project.main_group.files.find { |f| f.path == "Resources" }
    if existing
      UI.message("Resources folder reference already in pbxproj — skipping")
    else
      file_ref = project.main_group.new_reference("Resources")
      file_ref.last_known_file_type = "folder"
      file_ref.source_tree = "SOURCE_ROOT"

      resources_phase = target.resources_build_phase
      resources_phase.add_file_reference(file_ref, true)

      project.save
      UI.message("Patched pbxproj: added Resources/ folder reference for SpeakerECAPA.mlmodelc")
    end
  end

  private_lane :setup_signing do
    # A dedicated, ephemeral keychain avoids leaving secrets in the default one.
    keychain_name = "home-panel-ci.keychain-db"
    keychain_password = SecureRandom.hex(16)

    # Delete any leftover keychain from a previous failed run.
    sh("security delete-keychain #{keychain_name} 2>/dev/null || true")

    create_keychain(
      name: keychain_name,
      password: keychain_password,
      default_keychain: false,
      unlock: true,
      timeout: 1800,
      lock_when_sleeps: false,
    )

    p12_path = "/tmp/ios_distribution.p12"
    File.binwrite(p12_path, Base64.decode64(ENV.fetch("IOS_P12_BASE64")))

    import_certificate(
      certificate_path: p12_path,
      certificate_password: ENV.fetch("IOS_P12_PASSWORD"),
      keychain_name: keychain_name,
      keychain_password: keychain_password,
    )

    profile_path = "/tmp/HomePanel_AppStore.mobileprovision"
    File.binwrite(profile_path, Base64.decode64(ENV.fetch("IOS_PROVISIONING_PROFILE_BASE64")))

    install_provisioning_profile(path: profile_path)

    File.delete(p12_path) if File.exist?(p12_path)
  end

  # Overwrite the default Tauri icons in gen/apple's AppIcon.appiconset with
  # variants rendered from src-tauri/icons/icon.png. Without this, a fresh
  # `tauri ios init` on CI leaves the built-in Tauri "T" placeholder.
  private_lane :generate_icons do
    Dir.chdir(IOS_PROJECT_ROOT) do
      sh("pnpm tauri icon src-tauri/icons/icon.png")
    end
  end

  private_lane :stamp_build_number do
    # Only inject privacy strings here. CFBundleVersion is handled by
    # `tauri ios build --build-number` since Tauri rewrites Info.plist
    # from tauri.conf.json during the build and would clobber any
    # PlistBuddy patch we made at this stage.
    mic_reason = "Home Panel uses the microphone to recognise your voice commands."
    speech_reason = "Home Panel processes your voice locally to execute household commands."

    sh(<<~SHELL)
      set -e
      plist="#{INFO_PLIST}"
      set_or_add() {
        /usr/libexec/PlistBuddy -c "Set :$1 $3" "$plist" 2>/dev/null \
          || /usr/libexec/PlistBuddy -c "Add :$1 $2 $3" "$plist"
      }
      set_or_add NSMicrophoneUsageDescription string "#{mic_reason}"
      set_or_add NSSpeechRecognitionUsageDescription string "#{speech_reason}"
    SHELL
  end

  # Tauri's `gen/apple/` is regenerated from scratch on every CI run by
  # `tauri ios init`, so any manual change to Info.plist or
  # mobile_iOS.entitlements would get clobbered. Patch them here, after
  # `ensure_ios_project`, with the bits APNs push notifications need:
  #   - `aps-environment = production` in entitlements
  #   - `UIBackgroundModes` includes `remote-notification` in Info.plist
  # Both are idempotent: re-running with values already set is a no-op.
  private_lane :configure_push_capability do
    entitlements = File.join(TAURI_IOS_ROOT, "mobile_iOS", "mobile_iOS.entitlements")
    sh(<<~SHELL)
      set -e
      ent="#{entitlements}"
      /usr/libexec/PlistBuddy -c "Set :aps-environment production" "$ent" 2>/dev/null \
        || /usr/libexec/PlistBuddy -c "Add :aps-environment string production" "$ent"
    SHELL

    sh(<<~SHELL)
      set -e
      plist="#{INFO_PLIST}"
      # Make sure UIBackgroundModes is an array containing remote-notification.
      /usr/libexec/PlistBuddy -c "Print :UIBackgroundModes" "$plist" >/dev/null 2>&1 \
        || /usr/libexec/PlistBuddy -c "Add :UIBackgroundModes array" "$plist"
      # Idempotent: only append remote-notification when missing.
      /usr/libexec/PlistBuddy -c "Print :UIBackgroundModes" "$plist" \
        | grep -q "remote-notification" \
        || /usr/libexec/PlistBuddy -c "Add :UIBackgroundModes:0 string remote-notification" "$plist"
    SHELL
  end

  private_lane :build_tauri_ios do
    # On Xcode 26 the bare `xcodebuild ... archive` cargo-mobile2 issues
    # ends with "Archive Missing Bundle Identifier" because xcodebuild
    # logs "Using the first of multiple matching destinations" (a
    # simulator) and the archive's ApplicationProperties end up empty.
    # Drop a wrapper script earlier in PATH that re-invokes the real
    # xcodebuild with `-destination generic/platform=iOS` injected for
    # archive runs — leaves -showBuildSettings / -exportArchive /
    # -showsdks invocations untouched.
    xcwrap_dir = File.join(IOS_PROJECT_ROOT, ".fastlane-xcodebuild-shim")
    FileUtils.rm_rf(xcwrap_dir)
    FileUtils.mkdir_p(xcwrap_dir)
    File.write(File.join(xcwrap_dir, "xcodebuild"), <<~SH)
      #!/bin/bash
      # Inject -destination 'generic/platform=iOS' for archive actions
      # so Xcode 26 doesn't fall back to a simulator destination and
      # leave the archive without ApplicationProperties.
      for arg in "$@"; do
        if [ "$arg" = "archive" ]; then
          exec /usr/bin/xcodebuild -destination "generic/platform=iOS" "$@"
        fi
      done
      exec /usr/bin/xcodebuild "$@"
    SH
    FileUtils.chmod(0o755, File.join(xcwrap_dir, "xcodebuild"))
    ENV["PATH"] = "#{xcwrap_dir}:#{ENV.fetch('PATH')}"
    UI.message("Installed xcodebuild shim at #{xcwrap_dir}")
    sh("which xcodebuild", log: true)

    # `tauri ios build` runs xcodebuild build (which produces a signed
    # .app under DerivedData) and then xcodebuild archive. With the
    # shim above, the archive should now have proper destination and
    # complete cleanly — but if it doesn't, fall back to manual IPA
    # assembly from the salvaged .app.
    built_app_glob = File.expand_path(
      "Library/Developer/Xcode/DerivedData/mobile-*/Build/Products/release-iphoneos/Home Panel.app",
      Dir.home,
    )

    archive_failed = false
    begin
      Dir.chdir(IOS_PROJECT_ROOT) do
        sh(
          "pnpm tauri ios build --export-method app-store-connect",
          log: true,
        )
      end
      # Tauri's archive succeeded — find the IPA it produced and we're done.
      ipa_glob = File.join(TAURI_IOS_ROOT, "build", "**", "*.ipa")
      tauri_ipa = Dir.glob(ipa_glob).max_by { |p| File.mtime(p) }
      if tauri_ipa
        UI.success("tauri ios build produced #{tauri_ipa}")
        return
      end
      UI.important("tauri ios build returned 0 but no IPA was found under #{ipa_glob}; falling through to manual assembly.")
    rescue FastlaneCore::Interface::FastlaneShellError => e
      archive_failed = true
      UI.important("`tauri ios build` failed (#{e.message.lines.first.strip}); checking whether the build phase produced a usable .app to package manually.")
    end

    built_app = Dir.glob(built_app_glob).max_by { |p| File.mtime(p) }
    UI.user_error!("No built .app found under #{built_app_glob} after tauri ios build (archive_failed=#{archive_failed})") if built_app.nil?

    UI.message("Found built app at #{built_app}")

    # ROOT CAUSE of the 2026-04-30 server-side 409 "not signed using
    # submission certificate": xcodebuild on Xcode 26 + tauri-cli signs
    # the .app with `Identifier=Home Panel` (CFBundleName) instead of
    # the CFBundleIdentifier `com.matteopoli.homepanel`. Apple's
    # server-side validator compares the codesign Identifier to the
    # bundle id and rejects the mismatch — the rejection message is
    # misleading, the cert itself is fine.
    #
    # Fix: re-sign the top-level bundle with --identifier set to the
    # bundle id, preserving the entitlements that xcodebuild already
    # baked in (extracted from the existing signature). Nested bundles
    # (mlmodelc, storyboardc) keep their per-bundle identifiers.
    bundle_id = "com.matteopoli.homepanel"
    cert_name = "Apple Distribution: Matteo Poli (#{ENV.fetch('IOS_TEAM_ID')})"
    keychain = "home-panel-ci.keychain-db"
    ent_path = "/tmp/home-panel.entitlements.plist"
    sh("/usr/bin/codesign --display --entitlements :- '#{built_app}' > #{ent_path}", log: true)
    sh(
      "/usr/bin/codesign --force --sign '#{cert_name}' " \
      "--identifier '#{bundle_id}' " \
      "--entitlements '#{ent_path}' " \
      "--keychain '#{keychain}' " \
      "--preserve-metadata=runtime,flags " \
      "'#{built_app}'",
      log: true,
    )
    sh("/usr/bin/codesign -dvv '#{built_app}' 2>&1 | head -10", log: true)
    sh(
      "/usr/bin/security cms -D -i '/tmp/HomePanel_AppStore.mobileprovision' > /tmp/profile-decoded.plist && " \
      "/usr/libexec/PlistBuddy -c 'Print :Entitlements:get-task-allow' /tmp/profile-decoded.plist 2>&1 || true",
      log: true,
    )
    sh("/usr/bin/codesign --verify --deep --strict --verbose=2 '#{built_app}' 2>&1 || true", log: true)

    # Assemble Payload/Home Panel.app → IPA zip.
    payload_dir = File.join(TAURI_IOS_ROOT, "build", "Payload")
    ipa_dir = File.join(TAURI_IOS_ROOT, "build", "ipa")
    ipa_path = File.join(ipa_dir, "Home Panel.ipa")
    FileUtils.rm_rf(payload_dir)
    FileUtils.rm_rf(ipa_dir)
    FileUtils.mkdir_p(payload_dir)
    FileUtils.mkdir_p(ipa_dir)
    sh(
      "/usr/bin/ditto '#{built_app}' '#{File.join(payload_dir, File.basename(built_app))}'",
      log: true,
    )
    Dir.chdir(File.dirname(payload_dir)) do
      sh("/usr/bin/zip -qry '#{ipa_path}' Payload", log: true)
    end
    UI.message("Wrote IPA at #{ipa_path}")
  end

  private_lane :upload_build do
    ipa_glob = File.join(TAURI_IOS_ROOT, "build", "**", "*.ipa")
    ipa_path = Dir.glob(ipa_glob).max_by { |f| File.mtime(f) }
    UI.user_error!("No .ipa produced under #{ipa_glob}") if ipa_path.nil?
    UI.message("Uploading #{ipa_path}")

    # Bypass fastlane's upload_to_testflight (which calls altool, which
    # rejects Xcode 26-signed bundles with 409 'not signed using
    # submission certificate' even though every local check confirms
    # the firma is valid for App Store). Use iTMSTransporter directly —
    # same Apple-side validator but a different client implementation,
    # less affected by the altool-on-Xcode-26 regression.
    # altool resolves the API key by filename
    # ~/.appstoreconnect/private_keys/AuthKey_<KEY_ID>.p8
    key_dir = File.expand_path("~/.appstoreconnect/private_keys")
    FileUtils.mkdir_p(key_dir)
    key_path = File.join(key_dir, "AuthKey_#{ENV.fetch('ASC_API_KEY_ID')}.p8")
    File.binwrite(key_path, Base64.decode64(ENV.fetch("ASC_API_KEY_BASE64")))

    # iTMSTransporter on Xcode 26 just prints "now part of Transporter"
    # and exits. fastlane's upload_to_testflight wraps altool but on
    # Xcode 26 it consistently rejects with 409. Call altool directly
    # with --upload-app + -t ios + --verbose so we see the full server
    # response and can decide whether the rejection is real or an
    # altool-on-Xcode-26 bug we can route around.
    # Inspect the WWDR CA generation in the cert chain — App Store may
    # require a specific G6/G7 generation post-2026.
    sh("/usr/bin/security find-identity -v -p codesigning home-panel-ci.keychain-db | head -5", log: true)
    sh(
      "/usr/bin/security find-certificate -c 'Apple Distribution' -p home-panel-ci.keychain-db " \
      "| /usr/bin/openssl x509 -text -noout " \
      "| /usr/bin/grep -E 'Issuer:|Subject:|Not Before|Not After|Public Key Algorithm|Signature Algorithm' " \
      "| head -20",
      log: true,
    )

    # altool always exits 0 even when the upload is rejected; --output-format
    # json gives a structured response we can parse to fail loudly.
    output_log = "/tmp/altool-upload.log"
    json_path = "/tmp/altool-upload.json"
    sh(
      "/usr/bin/xcrun altool --upload-app " \
      "--type ios " \
      "--file '#{ipa_path}' " \
      "--apiKey #{ENV.fetch('ASC_API_KEY_ID')} " \
      "--apiIssuer #{ENV.fetch('ASC_API_KEY_ISSUER_ID')} " \
      "--output-format json " \
      "--verbose 2>&1 | tee '#{output_log}' " \
      "| /usr/bin/awk '/^\\{/,/^\\}$/' > '#{json_path}' || true",
      log: true,
    )
    if File.exist?(json_path) && !File.read(json_path).strip.empty?
      sh("/usr/bin/python3 -c \"import json; d=json.load(open('#{json_path}')); print(json.dumps(d, indent=2))\"", log: true)
      result = JSON.parse(File.read(json_path)) rescue {}
      errors = result["product-errors"] || result.dig("os-errors") || []
      if errors.any?
        UI.user_error!("altool upload failed: #{errors.first['message'] || errors.first}")
      end
    else
      UI.user_error!("altool produced no JSON output, check #{output_log}")
    end

  end
end
