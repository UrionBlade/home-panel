PORT=3000
HOST=0.0.0.0
DATABASE_URL=./data/home-panel.sqlite

# Token Bearer per proteggere /api/*. Genera con: openssl rand -base64 32
API_TOKEN=

# CORS — host autorizzati (separati da virgola). Default: dev locale Vite/Tauri.
CORS_ALLOWED_ORIGINS=http://localhost:1420,tauri://localhost,http://tauri.localhost

# Spotify (opzionale) — OAuth PKCE. Crea app su https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=

# SmartThings (opzionale) — Personal Access Token condiviso per lavatrice,
# asciugatrice e TV Samsung. Genera su https://account.smartthings.com/tokens
# con scope almeno: r:devices:*, x:devices:*, r:locations:*.
SMARTTHINGS_PAT=

# IKEA DIRIGERA hub (opzionale) — bridge per device Matter-over-Thread:
# lampadine KAJPLATS, sensori qualità aria ALPSTUGA, leak KLIPPBOK,
# temp/umidità TIMMERFLÖTTE.
#
# Setup one-time:
#   1. ./scripts/dirigera/auth.sh <hub-ip>
#   2. Premi il pulsante fisico sull'hub entro 60s.
#   3. Copia le due righe in output qui sotto.
#
# Lasciali vuoti per disabilitare l'integrazione (l'API parte comunque).
DIRIGERA_HOST=
DIRIGERA_TOKEN=
